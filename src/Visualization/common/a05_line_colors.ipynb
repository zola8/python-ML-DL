    "import numpy as np\n",
    "from matplotlib import pyplot as plt\n",
    "\n",
    "X = np.linspace(-np.pi, np.pi, 100)\n",
    "y = np.sin(X)\n",
    "colors = ['red', 'blue', 'green', 'yellow']\n",
    "\n",
    "for i in range(4):\n",
    "    plt.plot(X, np.sin(X + i), color = colors[i], alpha = 0.3)"
