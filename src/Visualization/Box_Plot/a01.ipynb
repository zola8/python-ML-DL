   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "data = [ [10, 12, 14, 15, 18, 20, 22],\n",
    "         [8, 9, 11, 13, 17, 19, 21],\n",
    "         [14, 16, 18, 20, 23, 25, 27] ]\n",
    "\n",
    "plt.boxplot(data)\n",
    "plt.xlabel(\"Groups\")\n",
    "plt.ylabel(\"Values\")\n",
    "plt.title(\"Box Plot\")\n",
    "plt.show()"
